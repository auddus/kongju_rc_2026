def main():
    string = "abc"
    string2 = "this is format tset: {}".format(10)
    print(string)
    print(string2)

    string3 = "this is format test: {2} {1} {0}".format(10, 20, 30)
    print(string3)
    string4 = "this is format test: {2:d} {1:5b} {0:05b}".format(-10, -20, -30)
    print(string4)  

    string5 = "this is format test: {2:+.2f} {1:+5.2f} {0:+05b.2f}".format(10.1263, -20.4213, 30)
    print(string5)

if __name__ == "__main__":
    main()
